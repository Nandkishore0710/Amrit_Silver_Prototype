NODE_ENV=development
PORT=5001

# MongoDB
MONGO_URI=mongodb://admin:password@localhost:27017/silverine?authSource=admin

# Redis
REDIS_URL=redis://:redispassword@localhost:6379

# JWT
JWT_SECRET=silverine_jwt_secret_change_in_production_2026
JWT_EXPIRE=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SILVERINE_WEBHOOK_SECRET

# Cloudinary (shared with silverkaari)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@silverine.com
SMTP_PASS=your_smtp_password

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# Frontend
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080

# Admin
ADMIN_EMAIL=admin@silverine.com

# Log level
LOG_LEVEL=info
