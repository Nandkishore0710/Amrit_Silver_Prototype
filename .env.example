# ──────────────────────────────────────────────────────────────────────
# Silverkaari + SilverIne — Root .env
# Copy this to .env and fill in your real values
# ──────────────────────────────────────────────────────────────────────

# ─── MongoDB ────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=change_in_production_2026

# ─── Redis ──────────────────────────────────────────────────────────
REDIS_PASSWORD=change_redis_password_2026

# ─── JWT ────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_me_2026
JWT_EXPIRE=7d

# ─── Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SILVERKAARI_STRIPE_WEBHOOK_SECRET
STRIPE_WEBHOOK_SECRET_SILVERINE=whsec_YOUR_SILVERINE_STRIPE_WEBHOOK_SECRET
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY

# ─── Cloudinary (shared) ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── SMTP / Email ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@silverkaari.com
SMTP_PASS=your_gmail_app_password

# ─── Google OAuth ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost/api/auth/google/callback
SILVERINE_GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# ─── Silverkaari frontend/backend URLs ─────────────────────────────
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost

# ─── SilverIne frontend/backend URLs ───────────────────────────────
SILVERINE_FRONTEND_URL=http://localhost:8080
SILVERINE_BACKEND_URL=http://localhost:8080

# ─── Admin Accounts ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@silverkaari.com

# ─── Mongo Express (dev) ────────────────────────────────────────────
ME_USERNAME=admin
ME_PASSWORD=mongoexpress_pass
